{
  "name": "@kodax/coding",
  "version": "0.7.23",
  "description": "KodaX Coding Agent - Coding 工具 + Prompts",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./repo-intelligence-bridge": {
      "types": "./dist/repo-intelligence/public-bridge.d.ts",
      "import": "./dist/repo-intelligence/public-bridge.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc --watch",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@kodax/agent": "*",
    "@kodax/ai": ">=0.5.0",
    "@kodax/core": "*",
    "@kodax/mcp": "*",
    "@kodax/session-lineage": "*",
    "@kodax/skills": "*"
  },
  "devDependencies": {
    "@lezer/common": "^1.5.1",
    "@lezer/go": "^1.0.1",
    "@lezer/python": "^1.1.18",
    "@lezer/rust": "^1.0.2",
    "@types/node": "^22.13.4",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "@kodax/ai": ">=0.5.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/icetomoyo/KodaX.git",
    "directory": "packages/coding"
  },
  "license": "Apache-2.0",
  "optionalDependencies": {
    "@lezer/common": "^1.5.1",
    "@lezer/go": "^1.0.1",
    "@lezer/python": "^1.1.18",
    "@lezer/rust": "^1.0.2"
  }
}
