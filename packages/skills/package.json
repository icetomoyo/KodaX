{
  "name": "@kodax/skills",
  "version": "0.7.3",
  "description": "KodaX Skills - Agent Skills standard implementation for KodaX",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b && npm run copy:builtin",
    "copy:builtin": "node -e \"require('fs').cpSync('src/builtin','dist/builtin',{recursive:true})\"",
    "dev": "tsc --watch",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/icetomoyo/KodaX.git",
    "directory": "packages/skills"
  },
  "license": "MIT",
  "dependencies": {
    "fflate": "^0.8.2",
    "yaml": "^2.8.2"
  }
}
