# Dependencies (reinstalled in container)
node_modules/

# Build output (rebuilt in container)
dist/
*.tsbuildinfo

# Git
.git/
.gitattributes

# IDE / Editor
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

